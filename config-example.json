{
  "domains": {
    "github.com": {
      "path_rules": {
        "/": {
          "h1_occurrence": 1,
          "footer_marker": "Footer"
        }
      }
    },
    "docs.github.com": {
      "path_rules": {
        "/": {
          "h1_occurrence": 1,
          "footer_marker": "Did this doc help you?"
        }
      }
    },
    "chatgpt.com": {
      "path_rules": {
        "/": {
          "h1_occurrence": 1,
          "footer_marker": ""
        }
      }
    }
  },
  "oauth": {
    "CLIENT_ID": "YOUR_GOOGLE_CLIENT_ID",
    "CLIENT_SECRET": "YOUR_GOOGLE_CLIENT_SECRET"
  },
  "browser": {
    "preferred": "chrome",
    "custom_path": {
      "chrome": "",
      "firefox": "",
      "edge": ""
    }
  },
  "logging": {
    "level": "INFO"
  }
}