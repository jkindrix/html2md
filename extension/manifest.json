{
  "manifest_version": 3,
  "name": "GRAB2MD",
  "version": "0.4.1",
  "description": "Convert web pages to Markdown with a single click",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "downloads",
    "scripting",
    "clipboardWrite"
  ]
}
